&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; T1[Target Host 1&amp;lt;br/&amp;gt;Ubuntu EC2&amp;lt;br/&amp;gt;172.31.1.243]
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; T2[Target Host 2&amp;lt;br/&amp;gt;Ubuntu EC2&amp;lt;br/&amp;gt;172.31.1.48]
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; T3[Target Host 3&amp;lt;br/&amp;gt;Ubuntu EC2&amp;lt;br/&amp;gt;172.31.1.5]
