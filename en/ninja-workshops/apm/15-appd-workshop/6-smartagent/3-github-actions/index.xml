&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; Runner --&amp;gt;|SSH:22&amp;lt;br/&amp;gt;Private IPs| T1
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; Runner --&amp;gt;|SSH:22&amp;lt;br/&amp;gt;Private IPs| T2
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; Runner --&amp;gt;|SSH:22&amp;lt;br/&amp;gt;Private IPs| T3
