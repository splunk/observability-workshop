<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Phase 1: Deploy Python Microservices on Splunk Observability Cloud Workshops</title><link>https://splunk.github.io/observability-workshop/en/ninja-workshops/instrumentation/19-context-propagation/2-deploy-application/</link><description>Recent content in Phase 1: Deploy Python Microservices on Splunk Observability Cloud Workshops</description><generator>Hugo</generator><language>en</language><atom:link href="https://splunk.github.io/observability-workshop/en/ninja-workshops/instrumentation/19-context-propagation/2-deploy-application/index.xml" rel="self" type="application/rss+xml"/><item><title>1. Install and Run the App</title><link>https://splunk.github.io/observability-workshop/en/ninja-workshops/instrumentation/19-context-propagation/2-deploy-application/1-install-and-run/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://splunk.github.io/observability-workshop/en/ninja-workshops/instrumentation/19-context-propagation/2-deploy-application/1-install-and-run/</guid><description>&lt;h2 id="prerequisites"&gt;
 &lt;span class="heading-text"&gt;Prerequisites&lt;/span&gt;
 &lt;a class="heading-anchor" href="#prerequisites" aria-label="Permalink" aria-hidden="true"&gt;#&lt;/a&gt;
