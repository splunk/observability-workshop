MERIDIAN_PORT=8090
MERIDIAN_LOAD_INTERVAL_SECONDS=2.0
MERIDIAN_INCIDENT_MODE=healthy

# Keep traces disabled for a no-credential local smoke test.
# Set OTEL_TRACES_EXPORTER=otlp when sending telemetry to a collector.
OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=meridian-workshop,app.workshop=meridian-delivery-promise,business.service=Medication Delivery Promise

# Optional Splunk Observability Cloud collector profile.
# docker compose --profile o11y up -d
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=replace-with-your-access-token

# Optional RUM browser agent injection in the patient portal.
# Leave unset for a backend-only workshop.
SPLUNK_RUM_REALM=us1
SPLUNK_RUM_ACCESS_TOKEN=
SPLUNK_RUM_APPLICATION_NAME=meridian-patient-portal
SPLUNK_RUM_ENVIRONMENT=meridian-workshop
SPLUNK_RUM_AGENT_VERSION=v3
