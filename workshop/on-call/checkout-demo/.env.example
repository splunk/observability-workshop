# Splunk Observability Cloud
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=replace-with-your-observability-access-token

# Workshop identity
ENVIRONMENT=on-call-workshop
SERVICE_VERSION=1.0.0

# Local app ports
CHECKOUT_APP_PORT=18080
INVENTORY_APP_PORT=18081

# Incident simulation defaults
ISSUE_MODE=healthy
ERROR_RATE=0.65
LATENCY_MS=2200
REQUEST_INTERVAL_SECONDS=1.0

# Collector
SPLUNK_OTEL_COLLECTOR_VERSION=latest
SPLUNK_MEMORY_LIMIT_MIB=512
