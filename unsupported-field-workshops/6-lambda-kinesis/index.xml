&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;✔ Function code deployed (6s)
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;Configuration did not change. Configuration update skipped. (6s)&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;

&lt;/div&gt;

&lt;div class="tabs" data-tabs&gt;
&lt;div class="tabs__list" role="tablist"&gt;&lt;button id="tabs-1-tab-0" class="tabs__btn is-active" role="tab" aria-selected="true" aria-controls="tabs-1-panel-0" tabindex="0" data-tab-label="Deploy Consumer Code"&gt;Deploy Consumer Code&lt;/button&gt;&lt;button id="tabs-1-tab-1" class="tabs__btn" role="tab" aria-selected="false" aria-controls="tabs-1-panel-1" tabindex="-1" data-tab-label="Expected Output"&gt;Expected Output&lt;/button&gt;
&lt;/div&gt;
&lt;div id="tabs-1-panel-0" class="tabs__panel is-active" role="tabpanel" aria-labelledby="tabs-1-tab-0" data-tab-label="Deploy Consumer Code"&gt;&lt;div class="code-block"&gt;
 &lt;div class="code-block__header"&gt;
 &lt;span class="code-block__file"&gt;&lt;span class="code-block__lang"&gt;bash&lt;/span&gt;&lt;/span&gt;
 &lt;button class="code-block__copy" type="button" aria-label="Copy code to clipboard"&gt;Copy&lt;/button&gt;
 &lt;/div&gt;
 &lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;sls deploy -f consumer&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div id="tabs-1-panel-1" class="tabs__panel" role="tabpanel" aria-labelledby="tabs-1-tab-1" hidden data-tab-label="Expected Output"&gt;&lt;div class="code-block"&gt;
