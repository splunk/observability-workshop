{
  "skills": {
    "project": [
      ".claude/skills/splunk-workshop-ja-translator",
      "Bash(npx markdownlint-cli:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-commit.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
